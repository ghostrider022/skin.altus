					<include content="WidgetScrollbar" condition="Skin.HasSetting(touchmode)">
						<param name="scrollbar_id" value="19099"/>
					</include>
				</control>
					</control>
				<include content="TopBar">
				<param name="breadcrumbs_label" value="" />
			</include>
			<include content="TopBar">
				<param name="breadcrumbs_label" value="" />
			</include>
			<include>BottomBar</include>
