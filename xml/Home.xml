						<top>180</top>
						<width>498</width>
						<height>832</height>
						<movement>9</movement>
						<focusposition>0</focusposition>
						<onfocus>ClearProperty(listposition,home)</onfocus>
						<!-- <onfocus>ClearProperty(FirstWidgetID,home)</onfocus>
						<onfocus>ClearProperty(LastWidgetID,home)</onfocus> -->
						<onfocus>ClearProperty(SpotlightWidget,Home)</onfocus>
